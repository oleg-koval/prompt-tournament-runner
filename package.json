{
  "name": "ai-refactor-playbook-runner",
  "version": "1.0.1",
  "description": "Markdown-driven AI refactor playbook runner with CLI and local web UI",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": {
    "name": "Oleg Koval",
    "email": "oleg@bizcuit.nl",
    "url": "https://olegkoval.com"
  },
  "homepage": "https://oleg-koval.github.io/ai-refactor-playbook-runner/",
  "repository": {
    "type": "git",
    "url": "https://github.com/oleg-koval/ai-refactor-playbook-runner.git"
  },
  "bugs": {
    "url": "https://github.com/oleg-koval/ai-refactor-playbook-runner/issues"
  },
  "keywords": [
    "playbook",
    "refactor",
    "typescript",
    "cli",
    "markdown"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "bin": {
    "ai-refactor-playbook-runner": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md",
    "examples"
  ],
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^3.1.3",
    "eslint": "^9.26.0",
    "lefthook": "^1.11.0",
    "prettier": "^3.5.3",
    "semantic-release": "^24.2.3",
    "tsup": "^8.4.0",
    "typedoc": "^0.28.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1",
    "vitest": "^3.1.3"
  },
  "scripts": {
    "build": "tsup",
    "build:docs": "typedoc --out docs/api src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run typecheck && npm run lint && npm run test:coverage",
    "semantic-release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "docs:index": "docs-index-keeper update",
    "prepare": "lefthook install"
  }
}
